{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Emotion",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Identificador único da emoção"
    },
    "emotionType": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "MOTIVADO",
        "ANIMADO",
        "SATISFEITO",
        "TRISTE",
        "MEDO",
        "CANSADO",
        "ANSIOSO",
        "PREOCUPADO",
        "ESTRESSADO",
        "RAIVA",
        null
      ],
      "description": "Tipo de emoção sentida pelo usuário"
    },
    "dayFelt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?$",
      "description": "Data e hora em que a emoção foi sentida (LocalDateTime ISO-8601)"
    },
    "userId": {
      "type": "string",
      "description": "Identificador do usuário que registrou a emoção"
    },
    "deleted": {
      "type": "boolean",
      "description": "Indica se a emoção foi marcada como deletada (soft delete)"
    }
  },
  "required": [
    "id",
    "emotionType",
    "dayFelt",
    "userId",
    "deleted"
  ]
}
